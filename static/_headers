# Gatsby hashed static assets - cache forever
/static/*
  Cache-Control: public, max-age=31536000, immutable

# Page data - revalidate on each request
/page-data/*
  Cache-Control: public, max-age=0, must-revalidate

# Service worker - always fresh
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

